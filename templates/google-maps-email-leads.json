    {
      "parameters": {
        "method": "POST",
        "url": "https://api.crawlora.net/api/v1/contact",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "url",
              "value": "={{ $json.website }}"
            }
          ]
        },
        "options": {}
      },
      "id": "11111111-1111-4111-8111-000000000004",
      "name": "Crawlora: find emails (Contact API)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        900,
        360
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_WITH_CRAWLORA_CREDENTIAL",
          "name": "Crawlora API (x-api-key)"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Combine each business (from the dataset search) with the emails found by the Contact API.\nconst biz = $('Split out businesses').item.json;\nconst contact = $json.data || {};\nconst emails = contact.emails || [];\n\n// Prefer a personal address; otherwise the first public one (often info@ / sales@).\nconst primary = emails.find((e) => e.type === 'personal') || emails[0] || {};\nconst socials = (contact.socials || [])\n  .map((s) => (typeof s === 'string' ? s : s.url || s.handle || ''))\n  .filter(Boolean);\n\nreturn {\n  json: {\n    business: biz.name || '',\n    category: Array.isArray(biz.category) ? biz.category.join(', ') : biz.category || '',\n    address: biz.address || '',\n    city: biz.city || '',\n    state: biz.state || '',\n    phone: biz.phone || '',\n    website: biz.website || '',\n    rating: biz.rating ?? '',\n    reviews: biz.review_count ?? '',\n    email: primary.email || '',\n    email_type: primary.type || '',\n    email_status: primary.status || '',\n    all_emails: emails.map((e) => e.email).join(', '),\n    socials: socials.join(', '),\n    place_id: biz.place_id || '',\n  },\n};"
      },
      "id": "11111111-1111-4111-8111-000000000005",
      "name": "Build lead row",
      "type": "n8n-nodes-base.code",
