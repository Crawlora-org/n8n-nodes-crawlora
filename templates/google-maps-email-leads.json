            },
            {
              "name": "page_size",
              "value": "20"
            }
          ]
        },
        "options": {}
      },
      "id": "11111111-1111-4111-8111-000000000002",
      "name": "Crawlora: Google Maps dataset search",
      "type": "n8n-nodes-base.httpRequest",
