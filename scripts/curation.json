  "Shopify": ["shopify-store", "shopify-products", "shopify-product", "shopify-collections"],
  "Shop.app": ["shop-app-search", "shop-app-product", "shop-app-product-reviews", "shop-app-shop"],

  "YouTube": [
    "youtube-search",
    "youtube-video",
